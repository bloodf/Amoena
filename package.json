{
  "name": "@lunaria/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "The AI Agent Operating System — Desktop IDE with agent orchestration, persistent memory, and extensibility",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LunariaAi/lunaria.git"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "desktop-ide",
    "electron",
    "multi-agent",
    "memory",
    "orchestration",
    "extensions"
  ],
  "packageManager": "bun@1.3.9",
  "overrides": {
    "react-is": "^19.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run desktop:dev",
    "build": "bun run desktop:build",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "bun run --cwd packages/ui test && bun run --cwd apps/dashboard test",
    "test:e2e": "bun run --cwd apps/dashboard test:e2e",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:build": "bun run --cwd apps/desktop build",
    "dashboard:dev": "bun run --cwd apps/dashboard dev",
    "dashboard:build": "bun run --cwd apps/dashboard build",
    "mobile:dev": "bun run --cwd apps/mobile start",
    "storybook": "bun run --cwd packages/ui storybook",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "type-check": "bunx tsc --noEmit -p packages/tokens/tsconfig.json && bunx tsc --noEmit -p packages/i18n/tsconfig.json && bunx tsc --noEmit -p packages/ui/tsconfig.json",
    "docs:dev": "bunx vitepress dev docs",
    "docs:build": "bunx vitepress build docs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/bun": "latest",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.3"
  },
  "lint-staged": {
    "packages/ui/**/*.{ts,tsx}": ["biome check --fix"],
    "packages/tokens/**/*.{ts,tsx}": ["biome check --fix"],
    "packages/i18n/**/*.{ts,tsx}": ["biome check --fix"]
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "next-themes": "^0.4.6"
  }
}
