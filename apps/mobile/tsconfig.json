{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@lunaria/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@lunaria/i18n/*": [
        "../../packages/i18n/src/*"
      ],
      "@lunaria/runtime-client": [
        "../../packages/runtime-client/src/index.ts"
      ]
    },
    "types": [
      "react-native"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
