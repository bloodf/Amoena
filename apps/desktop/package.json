{
  "name": "@lunaria/desktop-app",
  "version": "0.1.0",
  "private": true,
  "description": "Amoena desktop application — Electron + Vite + React",
  "license": "MIT",
  "author": {
    "name": "Amoena"
  },
  "productName": "Amoena",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmoenaAi/amoena.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "main": "dist/main/index.js",
  "resources": "resources",
  "scripts": {
    "dev": "vite",
    "build": "electron-vite build",
    "electron:dev": "electron .",
    "electron:build": "electron-vite build && bun run scripts/materialize-next.ts && electron-builder",
    "test": "bunx vitest run",
    "type-check": "bunx tsc --noEmit -p tsconfig.json",
    "e2e": "bunx playwright test",
    "e2e:ui": "bunx playwright test --ui"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2",
    "@ai-sdk/google": "^1.2",
    "@ai-sdk/openai": "^1.3",
    "@lunaria/amoena-service": "workspace:*",
    "@lunaria/i18n": "workspace:*",
    "@lunaria/runtime-client": "workspace:*",
    "@lunaria/ui": "workspace:*",
    "@sentry/electron": "^7.10.0",
    "@t3-oss/env-core": "^0.13.11",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@xterm/headless": "^6.0.0",
    "ai": "^4.3",
    "culori": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-is": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "superjson": "^2.2.5",
    "trpc-electron": "^0.1.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^4.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.0",
    "electron": "^36.0.0",
    "electron-vite": "^4.0.0",
    "electron-builder": "^26.0.0",
    "happy-dom": "^20.8.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.1.0",
    "@playwright/test": "^1.50.0"
  }
}
