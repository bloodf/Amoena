{
  "name": "@lunaria/desktop-app",
  "version": "0.1.0",
  "private": true,
  "description": "Lunaria desktop application — Tauri 2 + Vite + React",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LunariaAi/lunaria.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "scripts": {
    "dev": "bunx tauri dev",
    "dev:web": "bunx vite",
    "build": "bunx tauri build --debug --no-bundle",
    "build:web": "bunx vite build",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml && bunx vitest run",
    "type-check": "bunx tsc --noEmit -p tsconfig.json",
    "tauri:smoke": "cargo test --manifest-path src-tauri/Cargo.toml --test runtime_bootstrap --test transport_contract",
    "e2e": "bunx playwright test",
    "e2e:ui": "bunx playwright test --ui"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2",
    "@ai-sdk/google": "^1.2",
    "@ai-sdk/openai": "^1.3",
    "@lunaria/i18n": "workspace:*",
    "@lunaria/runtime-client": "workspace:*",
    "@lunaria/ui": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "ai": "^4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.8.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "@playwright/test": "^1.50.0"
  }
}
