		"shell-quote": "^1.8.3",
		"simple-git": "^3.30.0",
		"strip-ansi": "^7.1.2",
		"superjson": "^2.2.5",
		"tree-kill": "^1.2.2",
		"trpc-electron": "^0.1.2",
		"utf-8-validate": "^6.0.6",
