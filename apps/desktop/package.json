{
	"name": "@lunaria/desktop",
	"productName": "Lunaria",
	"description": "The last developer tool you'll ever need",
	"version": "1.3.0",
	"main": "./dist/main/index.js",
	"resources": "src/resources",
	"repository": {
		"type": "git",
		"url": "https://github.com/Lunaria/lunaria.git"
	},
	"author": {
		"name": "Lunaria",
		"email": "hi@lunaria.dev"
	},
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist dist-electron release node_modules",
		"start": "electron-vite preview",
		"generate:icons": "bun run scripts/generate-file-icons.ts",
		"predev": "cross-env NODE_ENV=development bun run clean:dev && bun run generate:icons && cross-env NODE_ENV=development bun run scripts/clean-launch-services.ts && cross-env NODE_ENV=development bun run scripts/patch-dev-protocol.ts",
		"dev": "cross-env NODE_ENV=development electron-vite dev --watch",
		"compile:app": "cross-env NODE_OPTIONS=--max-old-space-size=8192 electron-vite build",
		"copy:native-modules": "bun run scripts/copy-native-modules.ts",
		"validate:native-runtime": "bun run scripts/validate-native-runtime.ts",
		"prebuild": "bun run clean:dev && bun run generate:icons && bun run compile:app && bun run copy:native-modules && bun run validate:native-runtime",
		"build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
		"prepackage": "bun run copy:native-modules && bun run validate:native-runtime",
		"package": "electron-vite build && electron-builder --config electron-builder.ts",
		"package:mac": "electron-vite build && electron-builder --mac --config electron-builder.ts",
		"package:win": "electron-vite build && electron-builder --win --config electron-builder.ts",
		"package:linux": "electron-vite build && electron-builder --linux --config electron-builder.ts",
		"install:deps": "electron-builder install-app-deps",
		"release": "electron-builder --publish always",
		"clean:dev": "rimraf ./node_modules/.dev",
		"pretypecheck": "bun run generate:icons",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.43",
		"@ai-sdk/openai": "3.0.36",
		"@ai-sdk/react": "^3.0.0",
		"@ast-grep/napi": "^0.41.0",
		"@better-auth/stripe": "1.4.18",
		"@durable-streams/client": "^0.2.1",
		"@electric-sql/client": "1.5.12",
		"@hono/node-server": "^1.14.1",
		"@lunaria/auth": "workspace:*",
		"@lunaria/db": "workspace:*",
		"@lunaria/desktop-mcp": "workspace:*",
		"@lunaria/host-service": "workspace:*",
		"@lunaria/local-db": "workspace:*",
		"@lunaria/macos-process-metrics": "workspace:*",
		"@lunaria/shared": "workspace:*",
		"@lunaria/trpc": "workspace:*",
		"@lunaria/workspace-client": "workspace:*",
		"@lunaria/workspace-fs": "workspace:*",
		"@mastra/core": "^1.3.0",
		"@parcel/watcher": "^2.5.6",
		"@pierre/diffs": "^1.0.10",
		"@radix-ui/react-dialog": "^1.1.15",
