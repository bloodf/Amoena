		"@xterm/addon-clipboard": "0.3.0-beta.195",
		"@xterm/addon-fit": "0.12.0-beta.195",
		"@xterm/addon-image": "0.10.0-beta.195",
		"@xterm/addon-ligatures": "0.11.0-beta.195",
