		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@lunaria/typescript": "workspace:*",
		"@sentry/vite-plugin": "^4.7.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.2.17",
		"@types/http-proxy": "^1.17.17",
		"@types/lodash": "^4.17.20",
		"@types/node": "^24.9.1",
		"cross-env": "^10.0.0",
