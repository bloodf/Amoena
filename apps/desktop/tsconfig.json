{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["bun"],
		"baseUrl": ".",
		"paths": {
			"*": ["src/*"],
			"~/*": ["./*"]
		}
	},
	"include": [
		"./src",
		"electron.vite.config.ts",
		"electron-builder.ts",
		"index.d.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"dist-electron",
		"release",
		"src/**/templates/**",
		"src/resources/browser-extension"
	]
}
