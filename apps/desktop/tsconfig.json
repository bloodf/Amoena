{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@lunaria/i18n": ["../../packages/i18n/src/index.ts"],
      "@lunaria/i18n/*": ["../../packages/i18n/src/*"],
      "@lunaria/runtime-client": ["../../packages/runtime-client/src/index.ts"],
      "@lunaria/ui": ["../../packages/ui/src/index.ts"],
      "@lunaria/ui/*": ["../../packages/ui/src/*"],
      "@/*": ["../../packages/ui/src/*"]
    },
    "types": ["vite/client", "bun", "node"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "vitest.config.ts"]
}
