{
  "name": "@lunaria/cli",
  "version": "0.1.0",
  "description": "Amoena CLI — terminal interface for multi-agent orchestration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmoenaAi/amoena.git",
    "directory": "apps/tui"
  },
  "type": "module",
  "bin": {
    "amoena": "./bin/amoena.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "bunx vitest run",
    "type-check": "bunx tsc --noEmit"
  },
  "dependencies": {
    "ink": "^6.0.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "amoena",
    "cli",
    "ai",
    "multi-agent",
    "orchestration"
  ]
}
