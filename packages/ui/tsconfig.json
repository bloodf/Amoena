{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "noImplicitAny": false,
    "verbatimModuleSyntax": false,
    "types": ["bun", "node", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["*"],
      "bun:test": ["test/bun-test-shim.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".storybook/**/*.ts"
  ]
}
